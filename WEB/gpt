<!DOCTYPE html>

<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Meu Perfil</title>

<style>

body{
margin:0;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
font-family: Arial, Helvetica, sans-serif;
background: linear-gradient(120deg,#001529,#003366);
}

/* ===== FUNDO ANIMADO ===== */

.hero-bg-animation{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
z-index:-1;
}

.floating-shape{
position:absolute;
border-radius:50%;
filter:blur(60px);
opacity:0.6;
animation:float 20s infinite ease-in-out;
}

.shape-1{
width:400px;
height:400px;
background:rgba(255,255,255,0.2);
top:-100px;
left:-100px;
}

.shape-2{
width:350px;
height:350px;
background:rgba(255,255,255,0.15);
top:50%;
right:-100px;
}

.shape-3{
width:300px;
height:300px;
background:rgba(255,255,255,0.2);
bottom:-100px;
left:30%;
}

@keyframes float{
0%{transform:translate(0,0)}
50%{transform:translate(60px,-60px)}
100%{transform:translate(0,0)}
}

.particles{
position:absolute;
width:100%;
height:100%;
}

.particle{
position:absolute;
width:4px;
height:4px;
background:white;
border-radius:50%;
animation:particle 10s infinite;
}

@keyframes particle{
0%{transform:translateY(100vh);opacity:0}
20%{opacity:1}
100%{transform:translateY(-100px);opacity:0}
}

.particle:nth-child(1){left:10%;animation-delay:0s}
.particle:nth-child(2){left:20%;animation-delay:1s}
.particle:nth-child(3){left:30%;animation-delay:2s}
.particle:nth-child(4){left:40%;animation-delay:3s}
.particle:nth-child(5){left:50%;animation-delay:4s}
.particle:nth-child(6){left:60%;animation-delay:5s}
.particle:nth-child(7){left:70%;animation-delay:6s}
.particle:nth-child(8){left:80%;animation-delay:7s}
.particle:nth-child(9){left:90%;animation-delay:8s}
.particle:nth-child(10){left:95%;animation-delay:9s}

/* ===== CONTAINER ===== */

.container{
background:white;
padding:30px 40px;
border-radius:10px;
width:320px;
box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

h2{
text-align:center;
margin-bottom:20px;
}

label{
font-size:14px;
}

.erro{
color:red;
font-size:14px;
}

input{
display:block;
padding:8px;
width:100%;
border-radius:20px;
border:1px solid #ccc;
margin-top:3px;
}

.bordaVermelha{
border:2px solid red;
}

.bordaVerde{
border:2px solid green;
}

button{
width:100%;
padding:10px;
border:none;
border-radius:20px;
margin-top:10px;
color:white;
font-size:15px;
cursor:pointer;
background:linear-gradient(90deg,#3a0ca3,#00a8e8);
}

button:hover{
opacity:0.9;
}

.logout{
background:linear-gradient(90deg,#b00020,#ff3d3d);
}

</style>

</head>

<body>

<!-- FUNDO ANIMADO -->

<div class="hero-bg-animation">

<div class="floating-shape shape-1"></div>
<div class="floating-shape shape-2"></div>
<div class="floating-shape shape-3"></div>

<div class="particles">
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
<div class="particle"></div>
</div>

</div>

<div class="container">

<h2>Meu Perfil</h2>

<form id="formPerfil">

<label>Nome Completo</label> <input type="text" id="nome"> <span id="erroNome" class="erro"></span> <br>

<label>E-mail</label> <input type="email" id="email"> <span id="erroEmail" class="erro"></span> <br>

<label>Trocar senha (opcional)</label> <input type="password" id="senha" placeholder="Mínimo 8 caracteres"> <span id="erroSenha" class="erro"></span> <br>

<button type="submit" class="salvar">Salvar Alterações</button>

<button type="button" id="logout" class="logout">Sair</button>

</form>

</div>

<script src="05.PerfilUserComum.js"></script>

</body>
</html>
